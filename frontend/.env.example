# SEGURIDAD: el frontend NO usa API keys. Toda llamada a IA, SAT y datos
# pasa por el backend (/api/*); las credenciales viven SOLO en el servidor
# (royaltica-api/.env). No agregues claves aquí: cualquier variable VITE_*
# o inyectada por Vite termina visible en el código del navegador.
VITE_API_URL=http://localhost:8080
