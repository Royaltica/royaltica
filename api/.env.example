# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# ─── Database (PostgreSQL) ─────────────────────────────
# Runtime: rol de MÍNIMO privilegio (royaltica_app, sin superuser → RLS activo).
DATABASE_URL=postgresql://royaltica_app:<password>@localhost:5432/royaltica?schema=public
# Migraciones/seed: rol owner (npm run prisma:deploy lo usa automáticamente).
DATABASE_ADMIN_URL=postgresql://royaltica:royaltica@localhost:5432/royaltica?schema=public

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (sesiones propias del API) ────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRES_IN=8h
# Llave dedicada (≥32 chars) para cifrar los secretos TOTP del 2FA.
# Si falta, se deriva de JWT_SECRET. Generar: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# ─── Firebase Admin (verificación de ID tokens) ────────
# Del JSON de la cuenta de servicio (Firebase Console > Configuración
# del proyecto > Cuentas de servicio > Generar nueva clave privada).
# La private key va entre comillas y conserva los \n escapados.
# Si se dejan vacías, la app arranca pero /auth/* responde 503.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Google Cloud Storage (documentos KYC, CFDIs) ──────
GCS_BUCKET_NAME=
GCS_KEY_FILE=

# ─── Gemini (auditoría forense de facturas) ────────────
GEMINI_API_KEY=

# ─── Resend (emails transaccionales) ───────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@royaltica.com

# ─── Swagger (protección en producción) ────────────────
SWAGGER_USER=admin
SWAGGER_PASS=change-me

# Verificación SAT (mock en dev determinista, live en producción)
SAT_VERIFY_MODE=live

# ─── WhatsApp (Meta Cloud API) ──────────────────────────
# Envío de alertas y recordatorios de cobranza. Sin token, corre en stub.
WHATSAPP_PROVIDER=meta
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_FROM=
# Webhook entrante (respuestas de clientes a los recordatorios de cobranza).
# VERIFY_TOKEN: lo eliges tú y lo pegas igual en el panel de Meta.
# APP_SECRET: el "App Secret" de tu app de Meta (valida la firma HMAC).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
