    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "DATABASE_URL=\"$DATABASE_ADMIN_URL\" prisma migrate dev",
    "prisma:deploy": "DATABASE_URL=\"$DATABASE_ADMIN_URL\" prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
